<mxfile host="app.diagrams.net">
  <diagram name="Sequence Diagram">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Lifelines -->
        <mxCell id="admin" value="Admin" style="swimlane;vertical=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="120" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="camera" value="Camera" style="swimlane;vertical=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="20" width="120" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="detector" value="CrowdDetector" style="swimlane;vertical=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="140" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="counter" value="CrowdCounter" style="swimlane;vertical=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="20" width="140" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="alert" value="AlertService" style="swimlane;vertical=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="20" width="140" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="notify" value="NotificationService" style="swimlane;vertical=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="20" width="160" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="worker" value="TempleWorker" style="swimlane;vertical=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="20" width="160" height="500" as="geometry"/>
        </mxCell>

        <!-- Messages -->
        <mxCell id="m1" value="Login()" style="endArrow=block;" edge="1" parent="1" source="admin" target="camera">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="m2" value="Capture Frame()" style="endArrow=block;" edge="1" parent="1" source="camera" target="detector">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="m3" value="Detect People()" style="endArrow=block;" edge="1" parent="1" source="detector" target="counter">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="m4" value="Count Crowd()" style="endArrow=block;" edge="1" parent="1" source="counter" target="alert">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="m5" value="Threshold Exceeded" style="endArrow=block;" edge="1" parent="1" source="alert" target="notify">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="m6" value="Send Alert Message" style="endArrow=block;" edge="1" parent="1" source="notify" target="worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
